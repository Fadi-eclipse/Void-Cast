<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Void Cast</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>

  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="brand" href="/">
          <span class="brand-name"><span>Void</span> <span>Cast</span></span>
        </a>

        <a class="ghost-link" href="/">All casts</a>
      </header>

      <main class="form-layout">
        <section class="hero-panel upload-hero">
          <div class="hero-content">
            <h1>Add cast</h1>
          </div>
        </section>

        <form
          class="upload-form"
          data-cloud-name="<%= cloudName %>"
        >
          <label for="caption">Cast caption</label>
          <input id="caption" name="caption" placeholder="Signal title" />

          <label for="uploadedFile">Cast file</label>
          <input
            id="uploadedFile"
            type="file"
            name="uploadedFile"
            accept="image/*,video/*,application/pdf"
            required
          />

          <button type="button">Upload Cast</button>
          <p class="form-message" role="status" aria-live="polite"></p>
        </form>
      </main>
    </div>

    <script>
      const form = document.querySelector(".upload-form");
      const button = form.querySelector("button");
      const message = form.querySelector(".form-message");

      async function uploadCast() {
        const fileInput = form.querySelector("#uploadedFile");
        const captionInput = form.querySelector("#caption");
        const file = fileInput.files[0];

        if (!file) {
          message.textContent = "Please choose a file to upload.";
          return;
        }

        button.disabled = true;
        button.textContent = "Uploading...";
        message.textContent = "Sending cast to Cloudinary.";

        try {
          const signatureResponse = await fetch("/cloudinary-signature", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              caption: captionInput.value,
            }),
          });

          const signatureData = await signatureResponse.json();

          if (!signatureResponse.ok) {
            throw new Error(signatureData.error || "Could not prepare upload.");
          }

          const uploadData = new FormData();
          uploadData.append("file", file);
          uploadData.append("api_key", signatureData.apiKey);
          uploadData.append("timestamp", signatureData.timestamp);
          uploadData.append("folder", signatureData.folder);
          uploadData.append("signature", signatureData.signature);

          if (signatureData.context) {
            uploadData.append("context", signatureData.context);
          }

          const uploadResponse = await fetch(
            `https://api.cloudinary.com/v1_1/${signatureData.cloudName}/auto/upload`,
            {
              method: "POST",
              body: uploadData,
            },
          );
          const uploadResult = await uploadResponse.json();

          if (!uploadResponse.ok) {
            throw new Error(uploadResult.error?.message || "Upload failed.");
          }

          window.location.href = "/";
        } catch (error) {
          message.textContent = error.message;
          button.disabled = false;
          button.textContent = "Upload Cast";
        }
      }

      button.addEventListener("click", uploadCast);
      form.addEventListener("submit", (event) => {
        event.preventDefault();
        uploadCast();
      });
    </script>
  </body>
</html>
