<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Void Cast</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>

  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="brand" href="/">
          <span class="brand-name"><span>Void</span> <span>Cast</span></span>
        </a>

        <a class="action-link" href="/Add-cast">Add cast</a>
      </header>

      <main>
        <section class="hero-panel home-hero">
          <div class="hero-content">
            <h1>Cast into the void</h1>
          </div>

          <div class="hero-stats" aria-label="Upload stats">

          </div>
        </section>

        <% if (casts.length === 0) { %>
          <section class="empty-state">
            <div>
              <p class="eyebrow">No signal found</p>
              <h2>No uploads yet.</h2>
            </div>
            <a class="action-link" href="/Add-cast">Create first cast</a>
          </section>
        <% } %>

        <% if (casts.length > 0) { %>
          <section class="library-header">
            <div>
              <h2>Main Feed</h2>
            </div>
          </section>

          <section class="cast-grid" data-cast-grid aria-label="Uploaded casts">
            <% casts.forEach((cast) => { %>
              <article
                class="cast-card"
                data-cast-url="<%= cast.url %>"
                data-cast-type="<%= cast.resourceType %>"
                data-cast-caption="<%= cast.caption %>"
              >
                <div class="media-frame">
                  <% if (cast.resourceType === "image") { %>
                    <img src="<%= cast.url %>" alt="<%= cast.caption %>" />
                  <% } else if (cast.resourceType === "video") { %>
                    <video src="<%= cast.url %>" controls preload="metadata"></video>
                  <% } else { %>
                    <a class="file-preview" href="<%= cast.url %>" target="_blank">
                      <strong>Open file</strong>
                    </a>
                  <% } %>
                </div>
                <div class="cast-copy">
                  <h3><%= cast.caption %></h3>
                </div>
              </article>
            <% }) %>
          </section>
        <% } %>
      </main>
    </div>

    <% if (casts.length > 0) { %>
      <div class="cast-modal" data-cast-modal hidden>
        <button class="cast-modal-close" data-cast-modal-close aria-label="Close cast preview">×</button>
        <div class="cast-modal-panel">
          <div class="cast-modal-media" data-cast-modal-media></div>
          <div class="cast-modal-caption" data-cast-modal-caption></div>
        </div>
      </div>
    <% } %>

    <script>
      const castGrid = document.querySelector("[data-cast-grid]");
      const castModal = document.querySelector("[data-cast-modal]");
      const modalMedia = document.querySelector("[data-cast-modal-media]");
      const modalCaption = document.querySelector("[data-cast-modal-caption]");
      const modalClose = document.querySelector("[data-cast-modal-close]");

      if (castModal) {
        castModal.hidden = true;
      }

      const openCastModal = (cast) => {
        if (!castModal || !modalMedia || !modalCaption) return;

        modalMedia.innerHTML = "";
        modalCaption.textContent = cast.caption || "";

        if (cast.resourceType === "image") {
          const image = document.createElement("img");
          image.src = cast.url;
          image.alt = cast.caption || "Cast image";
          modalMedia.appendChild(image);
        } else if (cast.resourceType === "video") {
          const video = document.createElement("video");
          video.src = cast.url;
          video.controls = true;
          video.preload = "metadata";
          video.autoplay = true;
          modalMedia.appendChild(video);
        } else {
          const fileLink = document.createElement("a");
          fileLink.href = cast.url;
          fileLink.target = "_blank";
          fileLink.rel = "noopener noreferrer";
          fileLink.className = "file-preview file-preview--modal";
          fileLink.innerHTML = "<strong>Open file</strong>";
          modalMedia.appendChild(fileLink);
        }

        castModal.hidden = false;
        castModal.setAttribute("aria-hidden", "false");
        castModal.style.display = "grid";
        document.body.classList.add("modal-open");
      };

      const closeCastModal = () => {
        if (!castModal) return;
        castModal.hidden = true;
        castModal.setAttribute("aria-hidden", "true");
        castModal.style.display = "none";
        document.body.classList.remove("modal-open");
        if (modalMedia) modalMedia.innerHTML = "";
      };

      if (castGrid && castGrid.children.length > 0) {
        const cards = Array.from(castGrid.children);
        let currentColumnCount = 0;

        const getColumnCount = () => {
          if (window.matchMedia("(max-width: 620px)").matches) return 1;
          if (window.matchMedia("(max-width: 980px)").matches) return 2;
          return 5;
        };

        const arrangeCasts = () => {
          const columnCount = getColumnCount();

          if (columnCount === currentColumnCount) return;

          currentColumnCount = columnCount;
          castGrid.textContent = "";

          const columns = Array.from({ length: columnCount }, () => {
            const column = document.createElement("div");
            column.className = "cast-column";
            castGrid.appendChild(column);
            return column;
          });

          cards.forEach((card, index) => {
            columns[index % columnCount].appendChild(card);
          });
        };

        cards.forEach((card) => {
          card.addEventListener("click", (event) => {
            if (event.target.closest("a")) return;

            openCastModal({
              url: card.dataset.castUrl,
              resourceType: card.dataset.castType,
              caption: card.dataset.castCaption,
            });
          });
        });

        arrangeCasts();
        window.addEventListener("resize", arrangeCasts);
      }

      if (modalClose) {
        modalClose.addEventListener("click", closeCastModal);
      }

      if (castModal) {
        castModal.style.display = "none";
        castModal.setAttribute("aria-hidden", "true");

        castModal.addEventListener("click", (event) => {
          if (event.target === castModal) {
            closeCastModal();
          }
        });
      }

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && castModal && !castModal.hidden) {
          closeCastModal();
        }
      });
    </script>

  </body>
</html>
