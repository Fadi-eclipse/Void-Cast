<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Void Cast</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>

  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="brand" href="/">
          <span class="brand-name"><span>Void</span> <span>Cast</span></span>
        </a>

        <a class="action-link" href="/Add-cast">Add cast</a>
      </header>

      <main>
        <section class="hero-panel home-hero">
          <div class="hero-content">
            <h1>Cast into the void</h1>
          </div>

          <div class="hero-stats" aria-label="Upload stats">

            </div>
          </div>
        </section>

        <% if (casts.length === 0) { %>
          <section class="empty-state">
            <div>
              <p class="eyebrow">No signal found</p>
              <h2>No uploads yet.</h2>
            </div>
            <a class="action-link" href="/Add-cast">Create first cast</a>
          </section>
        <% } %>

        <% if (casts.length > 0) { %>
          <section class="library-header">
            <div>
              <p class="eyebrow">Latest transmissions</p>
              <h2>Upload library</h2>
            </div>
          </section>

          <section class="cast-grid" aria-label="Uploaded casts">
            <% casts.forEach((cast) => { %>
              <article class="cast-card">
                <div class="media-frame">
                  <span class="type-badge"><%= cast.resourceType %></span>
                  <% if (cast.resourceType === "image") { %>
                    <img src="<%= cast.url %>" alt="<%= cast.caption %>" />
                  <% } else if (cast.resourceType === "video") { %>
                    <video src="<%= cast.url %>" controls preload="metadata"></video>
                  <% } else { %>
                    <a class="file-preview" href="<%= cast.url %>" target="_blank">
                      <strong>Open file</strong>
                    </a>
                  <% } %>
                </div>
                <div class="cast-copy">
                  <h3><%= cast.caption %></h3>
                </div>
              </article>
            <% }) %>
          </section>
        <% } %>
      </main>
    </div>
<script>
  window.onload = function() {
    // Delays the action by 1000 milliseconds (1 second)
    setTimeout(function() {
      window.scrollTo({
        left: 0,
        top: 750, // Increased 2.5x from 300 pixels
        behavior: 'smooth'
      });
    }, 1000); 
  };
</script>


  </body>
</html>
